# ── Firebase client config ─────────────────────────────────────────────────
# GoogleService-Info.plist is PUBLIC client config (it ships inside every iOS app)
# and MUST be committed — otherwise Xcode Cloud / CI does a clean checkout WITHOUT
# it and the app crashes at launch because FirebaseApp.configure() can't find it.
# Do NOT re-ignore it. (google-services.json is the Android equivalent.)

# Android signing credentials
*.keystore
*.jks
keystore.properties
signing.properties
release.keystore

# ── Xcode ──────────────────────────────────────────────────────────────────
build/
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.xcuserstate
*.xcscmblueprint

# Swift Package Manager
.build/
Packages/
*.resolved
# Keep the Xcode package lock for reproducible Firebase resolution.
!EL PARKING APP.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# CocoaPods
Pods/
Podfile.lock
*.xcworkspace
!*.xcodeproj/*.xcworkspace
*.xcworkspace/contents.xcworkspacedata
!*.xcodeproj/project.xcworkspace/contents.xcworkspacedata

# Carthage
Carthage/Build/

# ── macOS ──────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes
__MACOSX/

# ── Environment & IDE ──────────────────────────────────────────────────────
.env
.env.*
!.env.example
.vscode/
*.swp
*~

# Web local Firebase config (public keys, but keep per-environment local)
web/firebase-config.js

# Cloud Functions dependencies are restored from package-lock.json
functions/node_modules/

# Firebase emulator output
firestore-debug.log
web/ap.rtf
