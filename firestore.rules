rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function userExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return userExists() && userData().status == 'active';
    }

    // Invite gate:
    // - New accounts should explicitly carry inviteAccepted.
    // - Legacy active accounts may not have this field yet, so default=true keeps rollout safe.
    function hasAcceptedInvite() {
      return userExists() && userData().get('inviteAccepted', true) == true;
    }

    // App access gate for non-/users data collections.
    function hasAppAccess() {
      return isActiveUser()
          && hasAcceptedInvite()
          && userData().get('needsFinishRegistration', false) == false;
    }

    function isAdmin() {
      return hasAppAccess() && userData().role == 'admin';
    }

    function myEmail() {
      return userExists() ? userData().email : null;
    }

    function validTimeString(t) {
      return t.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function isPrivileged() {
      return hasAppAccess() && userData().role == 'privileged';
    }

    // Returns true if the server clock has passed 18:00 Prague local time.
    // Prague = CET (UTC+1) in winter, CEST (UTC+2) in summer.
    // 18:00 CEST = 16:00 UTC  →  threshold: 16 * 3600 * 1000 ms into the UTC day.
    // In CET this evaluates to 17:00 local (1 h early) — acceptable approximation.
    function isAfter18LocalTime() {
      return (request.time.toMillis() % 86400000) >= (16 * 3600 * 1000);
    }

    // Local "today" midnight stored as UTC Timestamp:
    //   CEST: 00:00 Prague = 22:00 UTC previous day  →  todayUtcMidnight - 2h
    //   CET:  00:00 Prague = 23:00 UTC previous day  →  todayUtcMidnight - 1h
    // "Today" window: [todayUtcMidnight - 2h, todayUtcMidnight + 22h)
    //   (upper bound = earliest CEST "tomorrow" midnight, so no overlap)
    function bookingDateIsToday() {
      let nowMs            = request.time.toMillis();
      let todayUtcMidnight = nowMs - (nowMs % 86400000);
      let bookingMs        = request.resource.data.bookingDate.toMillis();
      return bookingMs >= (todayUtcMidnight - 2 * 3600 * 1000)
          && bookingMs <  (todayUtcMidnight + 22 * 3600 * 1000);
    }

    // "Tomorrow" window: [todayUtcMidnight + 22h, todayUtcMidnight + 47h)
    //   CEST tomorrow midnight = todayUtcMidnight + 22h
    //   CET  tomorrow midnight = todayUtcMidnight + 23h
    //   upper bound = todayUtcMidnight + 47h (CET day+2 midnight)
    function bookingDateIsTomorrow() {
      let nowMs            = request.time.toMillis();
      let todayUtcMidnight = nowMs - (nowMs % 86400000);
      let bookingMs        = request.resource.data.bookingDate.toMillis();
      return bookingMs >= (todayUtcMidnight + 22 * 3600 * 1000)
          && bookingMs <  (todayUtcMidnight + 47 * 3600 * 1000);
    }

    // "Today through today+3" window: [todayUtcMidnight - 2h, todayUtcMidnight + 95h)
    //   Lower bound = earliest CEST "today" midnight
    //   Upper bound = todayUtcMidnight + 95h (CET day+4 midnight, exclusive)
    function bookingDateIsWithin3Days() {
      let nowMs            = request.time.toMillis();
      let todayUtcMidnight = nowMs - (nowMs % 86400000);
      let bookingMs        = request.resource.data.bookingDate.toMillis();
      return bookingMs >= (todayUtcMidnight - 2 * 3600 * 1000)
          && bookingMs <  (todayUtcMidnight + 95 * 3600 * 1000);
    }

    function validBookingDocument(bookingId) {
      return request.resource.data.keys().hasAll([
          'id', 'title', 'spot', 'user', 'email', 'bookingDate',
          'fromTime', 'toTime', 'createdBy', 'createdAt', 'expiresAt'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'title', 'spot', 'user', 'email', 'bookingDate',
          'fromTime', 'toTime', 'createdBy', 'createdAt', 'expiresAt',
          'groupID', 'spotID', 'bookedForUid', 'updatedAt'
        ])
        && request.resource.data.id == bookingId
        && request.resource.data.title is string
        && request.resource.data.spot is string
        && request.resource.data.spot.matches('^Parking [0-9]+$')
        && request.resource.data.user is string
        && request.resource.data.email is string
        && request.resource.data.bookingDate is timestamp
        && validTimeString(request.resource.data.fromTime)
        && validTimeString(request.resource.data.toTime)
        && request.resource.data.fromTime < request.resource.data.toTime
        && request.resource.data.createdBy is string
        && request.resource.data.createdAt is timestamp
        && request.resource.data.expiresAt is timestamp
        && (!request.resource.data.keys().hasAny(['groupID'])
            || request.resource.data.groupID == null
            || request.resource.data.groupID is string)
        && (!request.resource.data.keys().hasAny(['spotID'])
            || request.resource.data.spotID is string)
        && (!request.resource.data.keys().hasAny(['bookedForUid'])
            || request.resource.data.bookedForUid is string)
        && (!request.resource.data.keys().hasAny(['updatedAt'])
            || request.resource.data.updatedAt is timestamp);
    }

    function bookingDateAllowedForActor() {
      return isAdmin()
        || (isPrivileged()
          && request.resource.data.createdBy == myEmail()
          && bookingDateIsWithin3Days())
        || (request.resource.data.email == myEmail()
          && request.resource.data.createdBy == myEmail()
          && (bookingDateIsToday()
            || (bookingDateIsTomorrow() && isAfter18LocalTime())));
    }

    function validBookingCreate(bookingId) {
      return validBookingDocument(bookingId)
        && bookingDateAllowedForActor()
        && companySpotPolicyAllows();
    }

    function validBookingUpdate(bookingId) {
      return validBookingDocument(bookingId)
        // Re-validate the company spot policy when EITHER the spot OR the date
        // changes. (Checking only the spot let a GrandVision user book a non-GV
        // spot same-day — allowed after 08:00 — then edit the date forward to
        // keep a non-GV spot in advance.)
        && ((request.resource.data.spot == resource.data.spot
              && request.resource.data.bookingDate == resource.data.bookingDate)
            || companySpotPolicyAllows())
        && (bookingDateAllowedForActor()
            || request.resource.data.bookingDate == resource.data.bookingDate)
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }

    function canModifyBooking() {
      // Case-insensitive so a stored email/createdBy that differs only in letter
      // case from the user's profile email still authorizes cancel/edit (the app
      // matches case-insensitively for display, so the rule must too).
      return resource.data.email.lower() == myEmail().lower()
        || resource.data.createdBy.lower() == myEmail().lower()
        || isAdmin();
    }

    // ── Company spot policy (effective 22 June 2026) ─────────────────────────
    // Spots 74–76 are reserved for GrandVision users, and GrandVision users
    // may ONLY book those spots. Exception: same-day bookings made after
    // 08:00 Prague local time are open to everyone on any free spot.
    // Admins are exempt (but the apps label 74–76 as GrandVision spots).

    function companyPolicyActive() {
      return request.time >= timestamp.date(2026, 6, 22);
    }

    function isGrandVisionSpot() {
      return request.resource.data.spot in ['Parking 74', 'Parking 75', 'Parking 76'];
    }

    function myCompany() {
      return userData().get('companyBadge', 'none');
    }

    // 08:00 CEST = 06:00 UTC (in CET this evaluates to 07:00 local — acceptable,
    // mirrors the isAfter18LocalTime approximation above).
    function isAfter8LocalTime() {
      return (request.time.toMillis() % 86400000) >= (6 * 3600 * 1000);
    }

    function sameDayReleaseApplies() {
      return bookingDateIsToday() && isAfter8LocalTime();
    }

    function companySpotPolicyAllows() {
      return !companyPolicyActive()
        || isAdmin()
        || sameDayReleaseApplies()
        || (isGrandVisionSpot()
              ? myCompany() == 'grandVision'
              : myCompany() != 'grandVision');
    }

    function validSpotLockDocument() {
      return request.resource.data.keys().hasOnly(['slots'])
        && request.resource.data.slots is list
        && request.resource.data.slots.size() <= 64;
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────

    match /users/{uid} {

      // ── Create ──────────────────────────────────────────────────────────────
      allow create: if signedIn() && (

        // Normal self-registration: locked to role=user + status=pending
        (request.auth.uid == uid
          && request.resource.data.role    == 'user'
          && request.resource.data.status  == 'pending'
          && request.resource.data.get('inviteAccepted', false) == false
          // companyBadge gates GrandVision spot access — never self-assignable
          && request.resource.data.get('companyBadge', 'none') != 'grandVision')

        // Admin creates an account for another user (typical path)
        || isAdmin()

        // Fallback for admin-provisioned accounts:
        // Firebase Android SDK may sign the newly-created secondary-app user into
        // the primary auth context before the secondary app is deleted, causing
        // request.auth.uid == newUserUid at write time (no doc exists yet, so
        // isAdmin() returns false and the normal admin path is blocked).
        // Allow self-create only when all admin-provisioning markers are present
        // and the document email matches the Firebase Auth token (prevents
        // impersonation of another account's UID).
        || (request.auth.uid == uid
          && request.resource.data.get('needsFinishRegistration', false) == true
          && request.resource.data.status        == 'active'
          && request.resource.data.get('inviteAccepted', false) == true
          && request.resource.data.email         == request.auth.token.email
          // The admin plants this marker (own auth context) BEFORE creating
          // the account — outsiders can mint Auth users but not this doc.
          && exists(/databases/$(database)/documents/invites/$(request.resource.data.email)))
      );

      // ── Read ────────────────────────────────────────────────────────────────
      // Own profile is always readable (needed during pending/approval, before the
      // account is active). Other profiles: only active app users (for booking-name
      // display) — this excludes pending/suspended/non-invited accounts from
      // harvesting every user's PII (email, plate, phone, role, strikes).
      allow get:  if request.auth.uid == uid || hasAppAccess();
      allow list: if isAdmin();

      // ── Update ──────────────────────────────────────────────────────────────
      allow update: if signedIn() && (

        // Finish-registration: admin-created user clears needsFinishRegistration.
        // Explicitly whitelisted so the path is unambiguous even if isAdmin()
        // misbehaves. Cannot touch role, status, email, uid, createdAt, or strike fields.
        (request.auth.uid == uid
          && resource.data.get('needsFinishRegistration', false)         == true
          && request.resource.data.get('needsFinishRegistration', false) == false
          && request.resource.data.get('inviteAccepted', false)          == true
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email', 'uid', 'createdAt', 'companyBadge',
                       'strikes', 'suspendedAt', 'suspensionCount', 'strikeHistory']))

        // Normal self-edit: cannot change role, status, email, or strike/suspension fields
        || (request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email', 'companyBadge',
                       'strikes', 'suspendedAt', 'suspensionCount', 'strikeHistory',
                       'inviteAccepted']))

        // Auto-lift: user can flip own suspension → active after the 14-day window.
        // Firestore enforces the time gate server-side; client logic is just an optimisation.
        || (request.auth.uid == uid
          && resource.data.status == 'suspended'
          && resource.data.suspendedAt is timestamp
          && request.time >= resource.data.suspendedAt + duration.value(14, 'd')
          && request.resource.data.status  == 'active'
          && request.resource.data.get('inviteAccepted', true) == resource.data.get('inviteAccepted', true)
          && request.resource.data.strikes == 0
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'email', 'uid', 'createdAt', 'companyBadge',
                       'strikeHistory', 'suspensionCount', 'suspendedAt', 'inviteAccepted']))

        // Strike decay: user can self-reduce strike count once 30+ days have passed
        // since their last warning. Only strikes and lastStrikeAt may change.
        || (request.auth.uid == uid
          && resource.data.status != 'suspended'
          && resource.data.strikes > 0
          && resource.data.lastStrikeAt is timestamp
          && request.time >= resource.data.lastStrikeAt + duration.value(30, 'd')
          && request.resource.data.strikes < resource.data.strikes
          && request.resource.data.strikes >= 0
          && request.resource.data.get('inviteAccepted', true) == resource.data.get('inviteAccepted', true)
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email', 'uid', 'createdAt', 'companyBadge',
                       'strikeHistory', 'suspensionCount', 'suspendedAt', 'inviteAccepted']))

        // Admin can update any field
        || isAdmin()
      );

      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // ── /bookings/{bookingId} ─────────────────────────────────────────────────

    match /bookings/{bookingId} {
      // All active users read all bookings — needed to display the parking grid
      allow read: if hasAppAccess();

      // Only admin-approved active users can create bookings.
      // Time strings must be valid HH:mm and in order.
      // Date rules by role:
      //   admin      → any date
      //   privileged → today through today+3
      //   user       → today (any time) OR tomorrow (only after 18:00 local)
      allow create: if hasAppAccess()
                    && validBookingCreate(bookingId);

      allow update: if hasAppAccess()
                    && canModifyBooking()
                    && validBookingUpdate(bookingId);

      allow delete: if hasAppAccess() && canModifyBooking();
    }

    // ── /spot_locks/{lockId} ──────────────────────────────────────────────────
    // Atomic conflict prevention — validated structurally

    match /spot_locks/{lockId} {
      allow read:            if hasAppAccess();
      allow create, update:  if hasAppAccess() && validSpotLockDocument();
      allow delete:          if isAdmin();
    }

    // ── /parkingSpots/{spotId} ────────────────────────────────────────────────

    match /parkingSpots/{spotId} {
      allow read:                    if hasAppAccess();
      allow create, update, delete:  if isAdmin();
    }

    // ── /announcements/{announcementId} ───────────────────────────────────────

    match /announcements/{announcementId} {
      allow read:                    if hasAppAccess();
      allow create, update, delete:  if isAdmin();
    }

    // ── /info_items/{infoId} ─────────────────────────────────────────────────

    match /info_items/{infoId} {
      allow read:                    if hasAppAccess();
      allow create, update, delete:  if isAdmin();
    }

    // ── /audit_log/{logId} ────────────────────────────────────────────────────
    // Append-only — nobody can modify or delete entries

    match /audit_log/{logId} {
      allow read:          if isAdmin();
      allow create:        if signedIn()
                           && request.resource.data.performedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── /broadcast_notifications/{notificationId} ─────────────────────────────

    match /broadcast_notifications/{notificationId} {
      allow read:                    if hasAppAccess();
      allow create, update, delete:  if isAdmin();
    }

    // ── /users/{uid}/notifications/{notifId} ─────────────────────────────────

    match /users/{uid}/notifications/{notifId} {
      allow read:   if signedIn() && request.auth.uid == uid;
      allow create: if isAdmin();
      allow update: if signedIn()
                    && request.auth.uid == uid
                    && request.resource.data.delivered == true
                    && resource.data.delivered == false
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['delivered']);
    }

    // ── /direct_notifications/{notifId} ───────────────────────────────────────
    // Email-addressed user notifications. Any active app user can send (no
    // /users email lookup needed, so privileged/non-admin senders aren't blocked);
    // only the named recipient can read it or mark it delivered.
    match /direct_notifications/{notifId} {
      allow read:   if signedIn() && resource.data.toEmail == userData().email;
      allow create: if hasAppAccess()
                    && request.resource.data.keys().hasOnly(['toEmail', 'title', 'body', 'delivered', 'createdAt'])
                    && request.resource.data.toEmail is string
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 200
                    && request.resource.data.body is string
                    && request.resource.data.body.size() <= 1000
                    && request.resource.data.delivered == false
                    && request.resource.data.createdAt is timestamp;
      allow update: if signedIn()
                    && resource.data.toEmail == userData().email
                    && request.resource.data.delivered == true
                    && resource.data.delivered == false
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['delivered']);
      allow delete: if isAdmin();
    }

    // ── /invites/{email} ──────────────────────────────────────────────────────
    // Admin-planted markers that authorize the provisioning fallback above.
    // exists() checks in rules don't require client read access.

    match /invites/{email} {
      allow create, delete: if isAdmin();
      allow read:           if isAdmin();
      allow update:         if false;
    }

    // ── /appConfig/{configId} ─────────────────────────────────────────────────

    match /appConfig/{configId} {
      allow read:                    if hasAppAccess();
      allow create, update, delete:  if isAdmin();
    }

    // ── Vehicle catalog (hosted miniatures + maker logos) ────────────────────
    // Single source of truth for vehicle artwork, editable on the fly from the
    // web admin "Vehicles" tool. Images are stored as base64 in /vehicleImages
    // (kept separate so the lightweight metadata in /vehicleCatalog & /vehicleMakers
    // loads cheaply and blobs are fetched once, then cached on-device).
    // Read: any signed-in user (artwork is non-sensitive and the car picker must
    // work during onboarding, before hasAppAccess() is true). Write: admin only.

    function validCatalogImage() {
      // base64 PNG/WebP, capped well under Firestore's 1 MiB document limit.
      return request.resource.data.keys().hasOnly(['data', 'format', 'w', 'h', 'updatedAt'])
        && request.resource.data.data is string
        && request.resource.data.data.size() <= 900000
        && request.resource.data.format in ['png', 'webp', 'jpeg'];
    }

    match /vehicleMakers/{makerId} {
      allow read:                    if signedIn();
      allow create, update, delete:  if isAdmin();
    }

    match /vehicleCatalog/{entryId} {
      allow read:                    if signedIn();
      allow create, update, delete:  if isAdmin();
    }

    match /vehicleImages/{imageId} {
      allow read:            if signedIn();
      allow create, update:  if isAdmin() && validCatalogImage();
      allow delete:          if isAdmin();
    }

    match /vehicleCatalogMeta/{docId} {
      allow read:                    if signedIn();
      allow create, update, delete:  if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
