rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ───────────────────────────────────────────────────────────────

    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userData() {
      return userDoc().data;
    }

    function userExists() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isActiveUser() {
      return userExists() && userData().status == 'active';
    }

    function isAdmin() {
      return isActiveUser() && userData().role == 'admin';
    }

    function myEmail() {
      return userExists() ? userData().email : null;
    }

    function validTimeString(t) {
      return t.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function isPrivileged() {
      return isActiveUser() && userData().role == 'privileged';
    }

    // Returns true if the server clock has passed 18:00 Prague local time.
    // Prague = CET (UTC+1) in winter, CEST (UTC+2) in summer.
    // 18:00 CEST = 16:00 UTC  →  threshold: 16 * 3600 * 1000 ms into the UTC day.
    // In CET this evaluates to 17:00 local (1 h early) — acceptable approximation.
    function isAfter18LocalTime() {
      return (request.time.toMillis() % 86400000) >= (16 * 3600 * 1000);
    }

    // Local "today" midnight stored as UTC Timestamp:
    //   CEST: 00:00 Prague = 22:00 UTC previous day  →  todayUtcMidnight - 2h
    //   CET:  00:00 Prague = 23:00 UTC previous day  →  todayUtcMidnight - 1h
    // "Today" window: [todayUtcMidnight - 2h, todayUtcMidnight + 22h)
    //   (upper bound = earliest CEST "tomorrow" midnight, so no overlap)
    function bookingDateIsToday() {
      let nowMs            = request.time.toMillis();
      let todayUtcMidnight = nowMs - (nowMs % 86400000);
      let bookingMs        = request.resource.data.bookingDate.toMillis();
      return bookingMs >= (todayUtcMidnight - 2 * 3600 * 1000)
          && bookingMs <  (todayUtcMidnight + 22 * 3600 * 1000);
    }

    // "Tomorrow" window: [todayUtcMidnight + 22h, todayUtcMidnight + 47h)
    //   CEST tomorrow midnight = todayUtcMidnight + 22h
    //   CET  tomorrow midnight = todayUtcMidnight + 23h
    //   upper bound = todayUtcMidnight + 47h (CET day+2 midnight)
    function bookingDateIsTomorrow() {
      let nowMs            = request.time.toMillis();
      let todayUtcMidnight = nowMs - (nowMs % 86400000);
      let bookingMs        = request.resource.data.bookingDate.toMillis();
      return bookingMs >= (todayUtcMidnight + 22 * 3600 * 1000)
          && bookingMs <  (todayUtcMidnight + 47 * 3600 * 1000);
    }

    // "Today through today+3" window: [todayUtcMidnight - 2h, todayUtcMidnight + 95h)
    //   Lower bound = earliest CEST "today" midnight
    //   Upper bound = todayUtcMidnight + 95h (CET day+4 midnight, exclusive)
    function bookingDateIsWithin3Days() {
      let nowMs            = request.time.toMillis();
      let todayUtcMidnight = nowMs - (nowMs % 86400000);
      let bookingMs        = request.resource.data.bookingDate.toMillis();
      return bookingMs >= (todayUtcMidnight - 2 * 3600 * 1000)
          && bookingMs <  (todayUtcMidnight + 95 * 3600 * 1000);
    }

    // ── /users/{uid} ──────────────────────────────────────────────────────────

    match /users/{uid} {

      // ── Create ──────────────────────────────────────────────────────────────
      allow create: if signedIn() && (

        // Normal self-registration: locked to role=user + status=pending
        (request.auth.uid == uid
          && request.resource.data.role    == 'user'
          && request.resource.data.status  == 'pending')

        // Admin creates an account for another user (typical path)
        || isAdmin()

        // Fallback for admin-provisioned accounts:
        // Firebase Android SDK may sign the newly-created secondary-app user into
        // the primary auth context before the secondary app is deleted, causing
        // request.auth.uid == newUserUid at write time (no doc exists yet, so
        // isAdmin() returns false and the normal admin path is blocked).
        // Allow self-create only when all admin-provisioning markers are present
        // and the document email matches the Firebase Auth token (prevents
        // impersonation of another account's UID).
        || (request.auth.uid == uid
          && request.resource.data.get('needsFinishRegistration', false) == true
          && request.resource.data.status        == 'active'
          && request.resource.data.emailVerified == true
          && request.resource.data.email         == request.auth.token.email)
      );

      // ── Read ────────────────────────────────────────────────────────────────
      // Any signed-in user can read any profile (needed for booking name display)
      allow get:  if signedIn();
      allow list: if isAdmin();

      // ── Update ──────────────────────────────────────────────────────────────
      allow update: if signedIn() && (

        // Finish-registration: admin-created user clears needsFinishRegistration.
        // Explicitly whitelisted so the path is unambiguous even if isAdmin()
        // misbehaves. Cannot touch role, status, email, uid, createdAt, or strike fields.
        (request.auth.uid == uid
          && resource.data.get('needsFinishRegistration', false)         == true
          && request.resource.data.get('needsFinishRegistration', false) == false
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email', 'uid', 'createdAt',
                       'strikes', 'suspendedAt', 'suspensionCount', 'strikeHistory']))

        // Normal self-edit: cannot change role, status, email, or strike/suspension fields
        || (request.auth.uid == uid
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email',
                       'strikes', 'suspendedAt', 'suspensionCount', 'strikeHistory']))

        // Auto-lift: user can flip own suspension → active after the 14-day window.
        // Firestore enforces the time gate server-side; client logic is just an optimisation.
        || (request.auth.uid == uid
          && resource.data.status == 'suspended'
          && resource.data.suspendedAt is timestamp
          && request.time >= resource.data.suspendedAt + duration.value(14, 'd')
          && request.resource.data.status  == 'active'
          && request.resource.data.strikes == 0
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'email', 'uid', 'createdAt',
                       'strikeHistory', 'suspensionCount', 'suspendedAt']))

        // Strike decay: user can self-reduce strike count once 30+ days have passed
        // since their last warning. Only strikes and lastStrikeAt may change.
        || (request.auth.uid == uid
          && resource.data.status != 'suspended'
          && resource.data.strikes > 0
          && resource.data.lastStrikeAt is timestamp
          && request.time >= resource.data.lastStrikeAt + duration.value(30, 'd')
          && request.resource.data.strikes < resource.data.strikes
          && request.resource.data.strikes >= 0
          && !request.resource.data.diff(resource.data).affectedKeys()
              .hasAny(['role', 'status', 'email', 'uid', 'createdAt',
                       'strikeHistory', 'suspensionCount', 'suspendedAt']))

        // Admin can update any field
        || isAdmin()
      );

      allow delete: if isAdmin() || (signedIn() && request.auth.uid == uid);
    }

    // ── /bookings/{bookingId} ─────────────────────────────────────────────────

    match /bookings/{bookingId} {
      // All active users read all bookings — needed to display the parking grid
      allow read: if isActiveUser();

      // Only admin-approved active users can create bookings.
      // Time strings must be valid HH:mm and in order.
      // Date rules by role:
      //   admin      → any date
      //   privileged → today through today+3
      //   user       → today (any time) OR tomorrow (only after 18:00 local)
      allow create: if isActiveUser()
                    && validTimeString(request.resource.data.fromTime)
                    && validTimeString(request.resource.data.toTime)
                    && request.resource.data.fromTime < request.resource.data.toTime
                    && (isAdmin()
                        || (isPrivileged() && bookingDateIsWithin3Days())
                        || (bookingDateIsToday()
                            || (bookingDateIsTomorrow() && isAfter18LocalTime())));

      allow update: if isActiveUser() && (
        resource.data.email == myEmail() ||
        resource.data.createdBy == myEmail() ||
        isAdmin()
      );

      allow delete: if isActiveUser() && (
        resource.data.email == myEmail() ||
        resource.data.createdBy == myEmail() ||
        isAdmin()
      );
    }

    // ── /spot_locks/{lockId} ──────────────────────────────────────────────────
    // Atomic conflict prevention — validated structurally

    match /spot_locks/{lockId} {
      allow read:            if isActiveUser();
      allow create, update:  if isActiveUser();
      allow delete:          if isAdmin();
    }

    // ── /parkingSpots/{spotId} ────────────────────────────────────────────────

    match /parkingSpots/{spotId} {
      allow read:                    if isActiveUser();
      allow create, update, delete:  if isAdmin();
    }

    // ── /announcements/{announcementId} ───────────────────────────────────────

    match /announcements/{announcementId} {
      allow read:                    if isActiveUser();
      allow create, update, delete:  if isAdmin();
    }

    // ── /info_items/{infoId} ─────────────────────────────────────────────────

    match /info_items/{infoId} {
      allow read:                    if isActiveUser();
      allow create, update, delete:  if isAdmin();
    }

    // ── /audit_log/{logId} ────────────────────────────────────────────────────
    // Append-only — nobody can modify or delete entries

    match /audit_log/{logId} {
      allow read:          if isAdmin();
      allow create:        if signedIn()
                           && request.resource.data.performedBy == request.auth.uid;
      allow update, delete: if false;
    }

    // ── /broadcast_notifications/{notificationId} ─────────────────────────────

    match /broadcast_notifications/{notificationId} {
      allow read:                    if isActiveUser();
      allow create, update, delete:  if isAdmin();
    }

    // ── /users/{uid}/notifications/{notifId} ─────────────────────────────────

    match /users/{uid}/notifications/{notifId} {
      allow read:   if signedIn() && request.auth.uid == uid;
      allow create: if isAdmin();
      allow update: if signedIn()
                    && request.auth.uid == uid
                    && request.resource.data.delivered == true
                    && resource.data.delivered == false;
    }

    // ── /appConfig/{configId} ─────────────────────────────────────────────────

    match /appConfig/{configId} {
      allow read:                    if isActiveUser();
      allow create, update, delete:  if isAdmin();
    }

    // ── Deny everything else ──────────────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
